{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "next": "recommended",
      "react": "recommended",
      "types": "recommended",
      "project": "recommended"
    },
    "rules": {
      "preset": "recommended",
      "nursery": {
        "recommended": true
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!.next",
      "!**/*.svg",
      "!public/sw.js",
      "!frontend/graphql/",
      "!graphql/"
    ]
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  }
}
