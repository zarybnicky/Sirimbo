    "@tsconfig/node18": "^18.2.4",
    "@types/body-parser": "~1.19.6",
    "@types/compression": "~1.8.1",
    "@types/express": "~5.0.3",
    "@types/html-to-text": "~9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "~1.9.10",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "~6.4.19",
    "@types/pg": "8.11.11",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.9",
    "eslint": "^9.22.0",
    "typescript": "~5.6.3"
  }
