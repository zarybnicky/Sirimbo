    "import:people": "node ./scripts/import_people_from_csv.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.363.0",
    "@aws-sdk/s3-request-presigner": "3.363.0",
    "@graphile/simplify-inflection": "8.0.0-beta.8",
    "body-parser": "~1.20.3",
    "compression": "~1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "express": "~4.21.2",
    "graphile-config": "^0.0.1-beta.18",
    "graphql": "^16.11.0",
    "handlebars": "^4.7.8",
    "helmet": "~8.1.0",
    "html-to-text": "~9.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.10.1",
    "nodemailer": "~6.9.16",
    "pg": "8.16.3",
    "postgraphile": "^5.0.0-beta.48",
    "tamedevil": "^0.0.0-beta.9",
    "uglify-js": "^3.19.3",
    "ws": "^8.18.3"
  },
  "installConfig": {
