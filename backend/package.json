    "@tsconfig/node24": "^24.0.1",
    "@types/body-parser": "~1.19.6",
    "@types/compression": "~1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "~5.0.4",
    "@types/html-to-text": "~9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "~1.9.10",
    "@types/node": "^24.9.1",
    "@types/nodemailer": "~6.4.20",
    "@types/pg": "8.15.5",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.11",
    "eslint": "^9.38.0",
    "typescript": "~5.9.3"
  }
