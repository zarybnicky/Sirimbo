{
  "name": "@rozpisovnik/worker",
  "version": "1.0.0",
  "repository": "https://github.com/zarybnicky/rozpisovnik",
  "author": "Jakub Zárybnický",
  "license": "MIT",
  "private": true,
  "bin": "./rozpisovnik-worker",
  "type": "module",
  "scripts": {
    "lint": "tsc && eslint . --cache --cache-location ~/.cache/eslint",
    "schema": "graphile-worker --schema-only",
    "start": "NODE_ENV=development nodemon -e ts --exec graphile-worker",
    "crawler": "node --experimental-strip-types crawler/dev.ts",
    "sql:generate": "pgtyped -c sql.config.json"
  },
  "dependencies": {
    "@hyperdx/node-opentelemetry": "^0.10.2",
    "@pgtyped/runtime": "^2.4.2",
    "@traversable/zod": "^0.0.57",
    "date-fns": "~2.30.0",
    "graphile-config": "1.0.0-rc.1",
    "graphile-worker": "^0.16.6",
    "handlebars": "^4.7.8",
    "helmet": "~8.1.0",
    "html-to-text": "~9.0.5",
    "mjml": "^4.16.1",
    "nodemailer": "~7.0.10",
    "pg": "8.16.3",
    "pg-cursor": "^2.15.3",
    "uglify-js": "^3.19.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@pgtyped/cli": "^2.4.3",
    "@tsconfig/node24": "^24.0.1",
    "@types/html-to-text": "~9.0.4",
    "@types/mjml": "^4.7.4",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "~7.0.3",
    "@types/pg": "~8.15.6",
    "@types/pg-cursor": "^2.7.2",
    "cac": "^7.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-de-morgan": "^2.0.0",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
